# ============================================================
# Hotel Nova – .gitignore
# ============================================================

# ------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ------------------------------------------------------------
# Environment & Secrets  ⚠️  Never commit these!
# ------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example


# ------------------------------------------------------------
# Build Outputs
# ------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/
.vercel/
.cache/


# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ------------------------------------------------------------
# Test & Coverage
# ------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
jest-results/


# ------------------------------------------------------------
# TypeScript
# ------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo


# ------------------------------------------------------------
# Package Manager Locks (keep only one – adjust as needed)
# ------------------------------------------------------------
# Uncomment the lock files you are NOT using to ignore them:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml


# ------------------------------------------------------------
# Runtime / Temp Files
# ------------------------------------------------------------
*.pid
*.seed
*.pid.lock
.tmp/
tmp/


# ------------------------------------------------------------
# Database & Storage
# ------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
uploads/
public/uploads/


# ------------------------------------------------------------
# Docker (local overrides only)
# ------------------------------------------------------------
docker-compose.override.yml


# ------------------------------------------------------------
# OS Artifacts
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ------------------------------------------------------------
# Editors & IDEs
# ------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
Session.vim
.netrwhist

# Emacs
\#*\#
.\#*


# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
*.local
*.bak
*.orig
.eslintcache
.stylelintcache
.parcel-cache/
storybook-static/
